# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000
# Vite admin dashboard (admin-frontend-react); must match the origin in the browser
ADMIN_URL=http://localhost:5173

# ─── Spring Boot Core API (proxied routes) ──────────────────────────────────
JAVA_API_URL=https://localhost:8000

# ─── Database ────────────────────────────────────────────────────────────────
# Docker Compose maps Postgres to localhost:5433 (see repo docker-compose.yml). Use 5432 only if you use a standalone DB on that port.
DATABASE_URL="postgresql://oceanbazar:secret@localhost:5433/oceanbazar?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
# Set to "true" to only print OTP to terminal (no real email/SMS in dev)
OTP_TERMINAL_ONLY=true

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="Oceanbazar <noreply@oceanbazar.com>"

# ─── SMS ─────────────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ─── Social OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/social/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/social/facebook/callback

INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_CALLBACK_URL=http://localhost:4000/api/auth/social/instagram/callback

# ─── Payments ────────────────────────────────────────────────────────────────
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

NAGAD_MERCHANT_ID=your_nagad_merchant_id
NAGAD_MERCHANT_KEY=your_nagad_merchant_key
NAGAD_BASE_URL=https://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASS=your_store_password
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# ─── Admin Catalog Studio (file-import scan default) ─────────────────────────
