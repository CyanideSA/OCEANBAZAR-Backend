generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String               @id @db.Char(8)
  name           String               @db.VarChar(255)
  email          String?              @unique @db.VarChar(255)
  phone          String?              @unique @db.VarChar(20)
  passwordHash   String?              @map("password_hash")
  userType       UserType             @default(retail) @map("user_type")
  accountStatus  AccountStatus        @default(active) @map("account_status")
  preferredLang  Lang                 @default(en) @map("preferred_lang")
  emailVerified  Boolean              @default(false) @map("email_verified")
  profileImage   String?              @map("profile_image")
  lifetimeSpend  Decimal              @default(0) @map("lifetime_spend") @db.Decimal(12, 2)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart           Cart?
  customer       Customer?
  obPointsLedger ObPointsLedger[]
  orders         Order[]
  paymentTxs     PaymentTransaction[]
  productReviews ProductReview[]
  savedAddresses SavedAddress[]
  socialAccounts SocialAccount[]
  tickets        Ticket[]

  @@map("users")
}

model Customer {
  userId      String   @id @map("user_id") @db.Char(8)
  companyName String?  @map("company_name") @db.VarChar(255)
  taxId       String?  @map("tax_id") @db.VarChar(100)
  segment     String?  @db.VarChar(64)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customers")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  target    String   @db.VarChar(255)
  code      String   @db.Char(6)
  type      OtpType
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([target, type])
  @@map("otp_codes")
}

model SocialAccount {
  id          Int            @id @default(autoincrement())
  userId      String         @map("user_id") @db.Char(8)
  provider    SocialProvider
  providerId  String         @map("provider_id") @db.VarChar(255)
  accessToken String?        @map("access_token")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("social_accounts")
}

model SavedAddress {
  id         Int     @id @default(autoincrement())
  userId     String  @map("user_id") @db.Char(8)
  label      String  @db.VarChar(100)
  line1      String
  line2      String?
  city       String  @db.VarChar(100)
  district   String  @db.VarChar(100)
  postalCode String? @map("postal_code") @db.VarChar(20)
  isDefault  Boolean @default(false) @map("is_default")
  orders     Order[]
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

model AdminUser {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(255)
  username     String     @unique @db.VarChar(100)
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash")
  role         AdminRole  @default(staff)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  auditLogs    AuditLog[]
  tickets      Ticket[]

  @@map("admin_users")
}

model Category {
  id              String            @id(map: "categories_pkey1") @db.Char(8)
  parentId        String?           @map("parent_id") @db.Char(8)
  nameEn          String            @map("name_en") @db.VarChar(255)
  nameBn          String            @map("name_bn") @db.VarChar(255)
  slug            String            @unique @db.VarChar(255)
  icon            String?           @db.VarChar(120)
  description     String?
  sortOrder       Int               @default(0) @map("sort_order")
  depth           Int               @default(0)
  path            String            @default("")
  is_leaf         Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  parent          Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_categories_parent")
  children        Category[]        @relation("CategoryTree")
  productBanners  ProductBanner[]
  products        Product[]

  @@index([parentId], map: "idx_categories_parent")
  @@index([path(ops: raw("gin_trgm_ops"))], map: "idx_categories_path", type: Gin)
  @@index([slug], map: "idx_categories_slug")
  @@map("categories")
}

model Brand {
  id        String    @id(map: "brands_pkey1") @db.Char(8)
  nameEn    String    @map("name_en") @db.VarChar(255)
  nameBn    String    @map("name_bn") @db.VarChar(255)
  slug      String    @unique(map: "brands_slug_key1") @db.VarChar(255)
  logoUrl   String?   @map("logo_url") @db.VarChar(500)
  sortOrder Int       @default(0) @map("sort_order")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  products  Product[]

  @@map("brands")
}

model Product {
  id                 String               @id(map: "products_pkey1") @db.Char(8)
  categoryId         String               @map("category_id") @db.Char(8)
  brandId            String?              @map("brand_id") @db.Char(8)
  sellerId           String?              @map("seller_id") @db.Char(8)
  titleEn            String               @map("title_en") @db.VarChar(500)
  titleBn            String               @map("title_bn") @db.VarChar(500)
  descriptionEn      String?              @map("description_en")
  descriptionBn      String?              @map("description_bn")
  brand              String?              @db.VarChar(255)
  sku                String?              @db.VarChar(100)
  status             String               @default("active") @db.VarChar(20)
  weight             Decimal?             @db.Decimal(8, 3)
  weightUnit         String?              @map("weight_unit") @db.VarChar(10)
  moq                Int                  @default(1)
  stock              Int                  @default(0)
  seoTitle           String?              @map("seo_title") @db.VarChar(255)
  seoDescription     String?              @map("seo_description")
  importSource       String?              @map("import_source")
  specifications     Json?
  attributesExtra    Json?                @map("attributes_extra")
  ratingAvg          Decimal?             @map("rating_avg") @db.Decimal(3, 2)
  reviewCount        Int                  @default(0) @map("review_count")
  brandLogoUrl       String?              @map("brand_logo_url") @db.VarChar(500)
  popularityRank     Int?                 @map("popularity_rank")
  popularityLabelEn  String?              @map("popularity_label_en") @db.VarChar(255)
  popularityLabelBn  String?              @map("popularity_label_bn") @db.VarChar(255)
  reviewsSnapshot    Json?                @map("reviews_snapshot")
  isFeatured         Boolean              @default(false) @map("is_featured")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  productAssets     ProductAsset[]
  productAttributes ProductAttribute[]
  productBanners    ProductBanner[]
  pricing           ProductPricing[]
  productTags       ProductTag[]
  variants          ProductVariant[]
  productReviews    ProductReview[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  tickets           Ticket[]
  brandRelation      Brand?               @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  category           Category             @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([brandId], map: "idx_products_brand")
  @@index([categoryId], map: "idx_products_category")
  @@index([status], map: "idx_products_status")
  @@index([titleEn(ops: raw("gin_trgm_ops"))], map: "idx_products_title", type: Gin)
  @@map("products")
}

model ProductPricing {
  id            Int          @id(map: "product_pricing_pkey1") @default(autoincrement())
  productId     String       @map("product_id") @db.Char(8)
  customerType  String       @map("customer_type") @db.VarChar(20)
  price         Decimal      @db.Decimal(12, 2)
  compareAt     Decimal?     @map("compare_at") @db.Decimal(12, 2)
  tier1MinQty   Int?         @map("tier1_min_qty")
  tier1Discount Decimal?     @map("tier1_discount") @db.Decimal(5, 2)
  tier2MinQty   Int?         @map("tier2_min_qty")
  tier2Discount Decimal?     @map("tier2_discount") @db.Decimal(5, 2)
  tier3MinQty   Int?         @map("tier3_min_qty")
  tier3Discount Decimal?     @map("tier3_discount") @db.Decimal(5, 2)
  sortOrder     Int?         @default(0) @map("sort_order")
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([productId, customerType], map: "product_pricing_product_id_customer_type_key1")
  @@map("product_pricing")
}

model ProductVariant {
  id            String   @id(map: "product_variants_pkey1") @db.Char(8)
  productId     String   @map("product_id") @db.Char(8)
  sku           String?  @db.VarChar(100)
  nameEn        String   @map("name_en") @db.VarChar(255)
  nameBn        String   @map("name_bn") @db.VarChar(255)
  attributes    Json
  priceOverride Decimal? @map("price_override") @db.Decimal(12, 2)
  stock         Int      @default(0)
  weight        Decimal? @db.Decimal(8, 3)
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("product_variants")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    String     @unique @map("user_id") @db.Char(8)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id           Int                      @id @default(autoincrement())
  cartId       Int                      @map("cart_id")
  productId    String                   @map("product_id") @db.Char(8)
  variantId    String?                  @map("variant_id") @db.Char(8)
  quantity     Int
  unitPrice    Decimal                  @map("unit_price") @db.Decimal(12, 2)
  customerType CustomerType             @map("customer_type")
  cart         Cart                     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product      Product                  @relation(fields: [productId], references: [id])
  variant      product_variants_legacy? @relation(fields: [variantId], references: [id])

  @@map("cart_items")
}

model Coupon {
  id        Int        @id @default(autoincrement())
  code      String     @unique @db.VarChar(50)
  type      CouponType
  value     Decimal    @db.Decimal(10, 2)
  minOrder  Decimal    @default(0) @map("min_order") @db.Decimal(12, 2)
  maxUses   Int?       @map("max_uses")
  usedCount Int        @default(0) @map("used_count")
  startsAt  DateTime   @map("starts_at") @db.Timestamptz(6)
  expiresAt DateTime?  @map("expires_at") @db.Timestamptz(6)
  active    Boolean    @default(true)
  orders    Order[]

  @@map("coupons")
}

model Order {
  id                String               @id @db.Char(8)
  orderNumber       String               @unique @map("order_number") @db.VarChar(20)
  userId            String               @map("user_id") @db.Char(8)
  status            String               @default("pending") @db.VarChar(20)
  customerType      String               @map("customer_type") @db.VarChar(20)
  subtotal          Decimal              @db.Decimal(12, 2)
  discount          Decimal              @default(0) @db.Decimal(12, 2)
  gst               Decimal              @db.Decimal(12, 2)
  shippingFee       Decimal              @map("shipping_fee") @db.Decimal(12, 2)
  serviceFee        Decimal              @map("service_fee") @db.Decimal(12, 2)
  obPointsUsed      Int                  @default(0) @map("ob_points_used")
  obDiscount        Decimal              @default(0) @map("ob_discount") @db.Decimal(12, 2)
  couponId          Int?                 @map("coupon_id")
  total             Decimal              @db.Decimal(12, 2)
  paymentMethod     String               @map("payment_method") @db.VarChar(20)
  paymentStatus     String               @default("unpaid") @map("payment_status") @db.VarChar(20)
  shippingAddressId Int?                 @map("shipping_address_id")
  trackingNumber    String?              @map("tracking_number") @db.Char(16)
  notes             String?
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  obPointsLedger    ObPointsLedger[]
  items             OrderItem[]
  timeline          OrderTimeline[]
  coupon            Coupon?              @relation(fields: [couponId], references: [id])
  shippingAddress   SavedAddress?        @relation(fields: [shippingAddressId], references: [id])
  user              User                 @relation(fields: [userId], references: [id])
  paymentTxs        PaymentTransaction[]
  productReviews    ProductReview[]
  shipments         Shipment[]
  tickets           Ticket[]

  @@map("orders")
}

model OrderItem {
  id           Int                      @id @default(autoincrement())
  orderId      String                   @map("order_id") @db.Char(8)
  productId    String                   @map("product_id") @db.Char(8)
  variantId    String?                  @map("variant_id") @db.Char(8)
  productTitle String                   @map("product_title") @db.VarChar(500)
  unitPrice    Decimal                  @map("unit_price") @db.Decimal(12, 2)
  quantity     Int
  lineTotal    Decimal                  @map("line_total") @db.Decimal(12, 2)
  discountPct  Decimal                  @default(0) @map("discount_pct") @db.Decimal(5, 2)
  order        Order                    @relation(fields: [orderId], references: [id])
  product      Product                  @relation(fields: [productId], references: [id])
  variant      product_variants_legacy? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderTimeline {
  id        Int       @id @default(autoincrement())
  orderId   String    @map("order_id") @db.Char(8)
  status    String    @db.VarChar(100)
  note      String?
  actorId   String?   @map("actor_id") @db.VarChar(50)
  actorType ActorType @map("actor_type")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  order     Order     @relation(fields: [orderId], references: [id])

  @@map("order_timeline")
}

model ObPointsLedger {
  id        Int          @id @default(autoincrement())
  userId    String       @map("user_id") @db.Char(8)
  type      ObPointsType
  points    Int
  orderId   String?      @map("order_id") @db.Char(8)
  note      String?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  order     Order?       @relation(fields: [orderId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@map("ob_points_ledger")
}

model PaymentTransaction {
  id           String          @id @db.Char(8)
  orderId      String          @map("order_id") @db.Char(8)
  userId       String          @map("user_id") @db.Char(8)
  method       PaymentMethod
  status       PaymentTxStatus @default(pending)
  providerTxId String?         @map("provider_tx_id") @db.VarChar(255)
  amount       Decimal         @db.Decimal(12, 2)
  currency     String          @default("BDT") @db.Char(3)
  metadata     Json?
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  order        Order           @relation(fields: [orderId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  tickets      Ticket[]

  @@map("payment_transactions")
}

model Shipment {
  id                String         @id @db.Char(8)
  orderId           String         @map("order_id") @db.Char(8)
  carrier           String         @db.VarChar(100)
  trackingNumber    String         @map("tracking_number") @db.Char(16)
  status            ShipmentStatus @default(pending)
  estimatedDelivery DateTime?      @map("estimated_delivery") @db.Date
  events            Json?
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  order             Order          @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

model ProductReview {
  id        String          @id @db.Char(8)
  userId    String          @map("user_id") @db.Char(8)
  productId String          @map("product_id") @db.Char(8)
  orderId   String?         @map("order_id") @db.Char(8)
  rating    Int
  title     String?         @db.VarChar(255)
  body      String?
  status    ReviewStatus    @default(pending)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  order     Order?          @relation(fields: [orderId], references: [id])
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, status])
  @@map("product_reviews")
}

model Ticket {
  id          String              @id @db.Char(8)
  userId      String              @map("user_id") @db.Char(8)
  orderId     String?             @map("order_id") @db.Char(8)
  productId   String?             @map("product_id") @db.Char(8)
  paymentTxId String?             @map("payment_tx_id") @db.Char(8)
  subject     String              @db.VarChar(500)
  status      TicketStatus        @default(open)
  priority    TicketPriority      @default(medium)
  category    TicketCategory
  assignedTo  Int?                @map("assigned_to")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages    TicketMessage[]
  admin       AdminUser?          @relation(fields: [assignedTo], references: [id])
  order       Order?              @relation(fields: [orderId], references: [id])
  paymentTx   PaymentTransaction? @relation(fields: [paymentTxId], references: [id])
  product     Product?            @relation(fields: [productId], references: [id])
  user        User                @relation(fields: [userId], references: [id])

  @@map("tickets")
}

model TicketMessage {
  id          Int        @id @default(autoincrement())
  ticketId    String     @map("ticket_id") @db.Char(8)
  senderType  SenderType @map("sender_type")
  senderId    String     @map("sender_id") @db.VarChar(50)
  message     String
  attachments String[]
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  seenAt      DateTime?  @map("seen_at") @db.Timestamptz(6)
  ticket      Ticket     @relation(fields: [ticketId], references: [id])

  @@map("ticket_messages")
}

model AuditLog {
  id         Int       @id @default(autoincrement())
  adminId    Int       @map("admin_id")
  action     String    @db.VarChar(255)
  targetType String    @map("target_type") @db.VarChar(100)
  targetId   String    @map("target_id") @db.VarChar(50)
  details    Json?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  admin      AdminUser @relation(fields: [adminId], references: [id])

  @@map("audit_logs")
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  eventType String   @map("event_type") @db.VarChar(100)
  userId    String?  @map("user_id") @db.Char(8)
  sessionId String?  @map("session_id") @db.VarChar(100)
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt])
  @@map("analytics_events")
}

model brands_legacy {
  id         String   @id(map: "brands_pkey") @db.Char(8)
  name_en    String   @db.VarChar(255)
  name_bn    String   @db.VarChar(255)
  slug       String   @unique(map: "brands_slug_key") @db.VarChar(255)
  logo_url   String?  @db.VarChar(500)
  sort_order Int      @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @db.Timestamptz(6)
}

model business_inquiries {
  id                   String    @id @db.VarChar(255)
  full_name            String    @db.VarChar(255)
  business_name        String?   @db.VarChar(255)
  email                String?   @db.VarChar(255)
  phone                String?   @db.VarChar(50)
  business_type        String?   @db.VarChar(100)
  country              String?   @db.VarChar(100)
  message              String?
  status               String    @default("pending") @db.VarChar(20)
  admin_notes          String?
  reviewed_by_admin_id String?   @db.VarChar(255)
  reviewed_at          DateTime? @db.Timestamptz(6)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @db.Timestamptz(6)
}

model categories_legacy {
  id                      String              @id(map: "categories_pkey") @db.Char(8)
  name_en                 String              @db.VarChar(255)
  name_bn                 String              @db.VarChar(255)
  parent_id               String?             @db.Char(8)
  icon                    String?
  sort_order              Int                 @default(0)
  created_at              DateTime            @default(now()) @db.Timestamptz(6)
  categories_legacy       categories_legacy?  @relation("categories_legacyTocategories_legacy", fields: [parent_id], references: [id], map: "categories_parent_id_fkey")
  other_categories_legacy categories_legacy[] @relation("categories_legacyTocategories_legacy")
}

model chat_sessions {
  id                 String    @id @db.VarChar(255)
  user_id            String    @db.VarChar(255)
  messages           Json?
  is_active          Boolean   @default(true)
  agent_engaged      Boolean   @default(false)
  closed_by_agent_at DateTime? @db.Timestamptz(6)
  last_message_at    DateTime  @default(now()) @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_chat_sessions_user_id")
}

model disputes {
  id                   String   @id @db.VarChar(255)
  order_id             String   @db.VarChar(255)
  user_id              String   @db.VarChar(255)
  title                String   @db.VarChar(500)
  description          String?
  status               String   @default("open") @db.VarChar(20)
  priority             String   @default("medium") @db.VarChar(20)
  assigned_to_admin_id String?  @db.VarChar(255)
  resolution_note      String?
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)
}

model domain_events {
  id               String    @id @db.VarChar(255)
  aggregate_type   String    @db.VarChar(50)
  aggregate_id     String    @db.VarChar(255)
  event_type       String    @db.VarChar(100)
  payload          Json?
  status           String    @default("pending") @db.VarChar(20)
  retry_count      Int       @default(0)
